---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/locales';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
    { params: { lang: 'pt' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projectTypes = [
  { value: 'backend', label: t('contact.projectTypeBackend') },
  { value: 'automation', label: t('contact.projectTypeAutomation') },
  { value: 'ai', label: t('contact.projectTypeAI') },
  { value: 'consulting', label: t('contact.projectTypeConsulting') },
  { value: 'other', label: t('contact.projectTypeOther') },
];

const whatsappNumber = '51969672749';
const whatsappLink = `https://wa.me/${whatsappNumber}`;
const emailLink = 'mailto:sergiopezoj@gmail.com';
const linkedinLink = 'https://linkedin.com/in/sergio-pezo';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<Layout title={t('seo.contactTitle')} description={t('seo.contactDescription')}>
  {turnstileSiteKey && (
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
  )}

  <main class="page-shell contact-page">
    <section class="contact-grid">
      <aside class="section-card contact-intro accent-blue">
        <p class="kicker">{t('nav.contact')}</p>
        <h1 class="gradient-title">{t('contact.title')}</h1>
        <p class="contact-subtitle">{t('contact.subtitle')}</p>

        <div class="contact-channels">
          <p class="mini-title">{t('contact.channelsTitle')}</p>
          <ul>
            <li>
              <a href={emailLink}>
                <span class="channel-label">{t('contact.directEmail')}</span>
                <span class="channel-value">sergiopezoj@gmail.com</span>
              </a>
            </li>
            <li>
              <a href={whatsappLink} target="_blank" rel="noreferrer">
                <span class="channel-label">{t('contact.whatsapp')}</span>
                <span class="channel-value">+51 969 672 749</span>
              </a>
            </li>
            <li>
              <a href={linkedinLink} target="_blank" rel="noreferrer">
                <span class="channel-label">{t('contact.linkedin')}</span>
                <span class="channel-value">/in/sergio-pezo</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>

      <section class="section-card contact-form-card">
        <form class="contact-form" id="contact-form" novalidate>
          <label class="contact-field">
            <span>{t('contact.name')}</span>
            <input type="text" name="name" required autocomplete="name" placeholder={t('contact.namePlaceholder')} />
          </label>

          <label class="contact-field">
            <span>{t('contact.email')}</span>
            <input type="email" name="email" required autocomplete="email" placeholder={t('contact.emailPlaceholder')} />
          </label>

          <label class="contact-field">
            <span>{t('contact.company')}</span>
            <input type="text" name="company" autocomplete="organization" placeholder={t('contact.companyPlaceholder')} />
          </label>

          <label class="contact-field">
            <span>{t('contact.projectType')}</span>
            <select name="projectType" required>
              {projectTypes.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="contact-field full">
            <span>{t('contact.message')}</span>
            <textarea name="message" required rows="6" placeholder={t('contact.messagePlaceholder')}></textarea>
          </label>

          <div class="honeypot" aria-hidden="true">
            <label>
              <span>Do not fill</span>
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <input type="hidden" name="locale" value={lang} />

          {turnstileSiteKey && (
            <div class="contact-field full verify-field">
              <span>{t('contact.verifyHuman')}</span>
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="light"
                data-size="flexible"
              ></div>
            </div>
          )}

          <button
            type="submit"
            class="contact-submit"
            data-send-label={t('contact.send')}
            data-sending-label={t('contact.sending')}
          >
            {t('contact.send')}
          </button>

          <p
            class="contact-status"
            data-status
            role="status"
            aria-live="polite"
            data-success={t('contact.success')}
            data-error={t('contact.error')}
            data-verify-error={t('contact.verifyError')}
            data-verify-missing={t('contact.verifyMissing')}
            data-captcha-enabled={turnstileSiteKey ? 'true' : 'false'}
          ></p>
        </form>
      </section>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = form?.querySelector<HTMLParagraphElement>('[data-status]') ?? null;
  const submitBtn = form?.querySelector<HTMLButtonElement>('.contact-submit') ?? null;

  if (form && status && submitBtn) {
    const sendLabel = submitBtn.dataset.sendLabel ?? 'Send';
    const sendingLabel = submitBtn.dataset.sendingLabel ?? 'Sending…';
    const successMsg = status.dataset.success ?? '';
    const errorMsg = status.dataset.error ?? '';
    const verifyErrorMsg = status.dataset.verifyError ?? errorMsg;
    const verifyMissingMsg = status.dataset.verifyMissing ?? errorMsg;
    const captchaEnabled = status.dataset.captchaEnabled === 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = '';
      status.classList.remove('is-success', 'is-error');

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      if (captchaEnabled) {
        const token = typeof payload['cf-turnstile-response'] === 'string'
          ? (payload['cf-turnstile-response'] as string).trim()
          : '';
        if (!token) {
          status.textContent = verifyMissingMsg;
          status.classList.add('is-error');
          return;
        }
      }

      submitBtn.disabled = true;
      submitBtn.textContent = sendingLabel;

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.ok) {
          const code = typeof data?.error === 'string' ? data.error : 'request_failed';
          throw new Error(code);
        }
        status.textContent = successMsg;
        status.classList.add('is-success');
        form.reset();
      } catch (err) {
        const code = err instanceof Error ? err.message : 'request_failed';
        status.textContent = code === 'captcha_failed' ? verifyErrorMsg : errorMsg;
        status.classList.add('is-error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = sendLabel;
        const turnstile = (window as any).turnstile;
        if (captchaEnabled && turnstile && typeof turnstile.reset === 'function') {
          try { turnstile.reset(); } catch {}
        }
      }
    });
  }
</script>

<style>
  .contact-page {
    display: grid;
    gap: 1.25rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .contact-intro {
    padding: 1.8rem;
    display: grid;
    gap: 1.1rem;
    align-content: start;
    position: sticky;
    top: 6rem;
  }

  .contact-intro h1 {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 2.7rem);
  }

  .contact-subtitle {
    margin: 0;
    color: rgba(45, 37, 32, 0.78);
    max-width: 34rem;
  }

  .contact-channels {
    margin-top: 0.4rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(177, 144, 116, 0.28);
  }

  .contact-channels ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .contact-channels a {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.7rem 0.9rem;
    border-radius: 14px;
    background: rgba(70, 112, 142, 0.06);
    border: 1px solid rgba(70, 112, 142, 0.14);
    text-decoration: none;
    color: var(--ink);
    transition: 180ms ease;
  }

  .contact-channels a:hover {
    background: rgba(70, 112, 142, 0.12);
    transform: translateY(-1px);
  }

  .channel-label {
    font-weight: 600;
    color: var(--blue);
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .channel-value {
    font-size: 0.96rem;
    color: rgba(45, 37, 32, 0.82);
    word-break: break-all;
  }

  .contact-form-card {
    padding: 1.8rem;
  }

  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }

  .contact-field {
    display: grid;
    gap: 0.38rem;
    font-size: 0.94rem;
  }

  .contact-field.full,
  .contact-form > button,
  .contact-status,
  .verify-field {
    grid-column: 1 / -1;
  }

  .contact-field span {
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .contact-field input,
  .contact-field select,
  .contact-field textarea {
    font: inherit;
    padding: 0.8rem 0.95rem;
    border-radius: 14px;
    border: 1px solid rgba(45, 37, 32, 0.18);
    background: rgba(255, 252, 248, 0.9);
    color: var(--ink);
    outline: none;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .contact-field textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact-field input:focus,
  .contact-field select:focus,
  .contact-field textarea:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(70, 112, 142, 0.18);
  }

  .verify-field .cf-turnstile {
    margin-top: 0.2rem;
    min-height: 65px;
  }

  .honeypot {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-submit {
    margin-top: 0.4rem;
    padding: 1rem 1.2rem;
    border-radius: 999px;
    border: 1px solid var(--blue);
    background: var(--blue);
    color: #fff;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: transform 150ms ease, opacity 150ms ease;
  }

  .contact-submit:hover {
    transform: translateY(-1px);
  }

  .contact-submit:disabled {
    opacity: 0.7;
    cursor: progress;
  }

  .contact-status {
    margin: 0;
    font-size: 0.94rem;
    min-height: 1.2rem;
  }

  .contact-status.is-success {
    color: #2f6f4a;
  }

  .contact-status.is-error {
    color: #b14545;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-intro {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .contact-form {
      grid-template-columns: 1fr;
    }
    .contact-channels a {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
