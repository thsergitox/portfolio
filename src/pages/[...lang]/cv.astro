---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl } from "../../i18n/locales";
import { getProfile, type Lang } from "../../data/profile";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
    { params: { lang: "pt" } },
  ];
}

const lang = getLangFromUrl(Astro.url) as Lang;
const cv = getProfile(lang);

const labels = {
  es: {
    print: "Imprimir",
    summary: "Perfil profesional",
    experience: "Experiencia profesional",
    education: "Educación",
    projects: "Proyectos",
    awards: "Hackathons y premios",
    leadership: "Liderazgo y actividades",
    skills: "Habilidades",
    languages: "Idiomas",
  },
  en: {
    print: "Print",
    summary: "Professional profile",
    experience: "Experience",
    education: "Education",
    projects: "Projects",
    awards: "Hackathons and awards",
    leadership: "Leadership and activities",
    skills: "Skills",
    languages: "Languages",
  },
  pt: {
    print: "Imprimir",
    summary: "Perfil profissional",
    experience: "Experiência profissional",
    education: "Educação",
    projects: "Projetos",
    awards: "Hackathons e prêmios",
    leadership: "Liderança e atividades",
    skills: "Habilidades",
    languages: "Idiomas",
  },
}[lang];
---

<Layout title="CV">
  <main transition:animate>
    <div class="cv-container">
      <div class="cv-actions">
        <button onclick="window.print()" class="action-btn">{labels.print}</button>
        <a href="/cv.pdf" download class="action-btn">PDF</a>
      </div>

      <header class="cv-header">
        <h1 class="cv-name">Sergio Sebastián Pezo Jiménez</h1>
        <p class="cv-title">{cv.metaTitle}</p>
        <div class="cv-contact">
          <span>{cv.location}</span>
          <span>•</span>
          <span>{cv.phone}</span>
          <span>•</span>
          <span>{cv.email}</span>
          <span>•</span>
          <span>{cv.linkedin}</span>
          <span>•</span>
          <span>{cv.github}</span>
        </div>
      </header>

      <section class="cv-section">
        <h2>{labels.summary}</h2>
        <p>{cv.summary}</p>
      </section>

      <section class="cv-section">
        <h2>{labels.education}</h2>
        {
          cv.education.map((item) => (
            <article class="entry">
              <div class="entry-header">
                <div>
                  <h3>{item.institution}</h3>
                  <p>{item.program}</p>
                </div>
                <span class="period">{item.period}</span>
              </div>
              <p class="meta">{item.location}</p>
              <ul>
                {item.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h2>{labels.experience}</h2>
        {
          cv.experience.map((job) => (
            <article class="entry">
              <div class="entry-header">
                <div>
                  <h3>{job.role}</h3>
                  <p>{job.company} · {job.location}</p>
                </div>
                <span class="period">{job.period}</span>
              </div>
              <ul>
                {job.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h2>{labels.projects}</h2>
        {
          cv.projects.map((project) => (
            <article class="entry">
              <div class="entry-header">
                <div>
                  <h3>{project.title}</h3>
                  <p>{project.stack.join(", ")}</p>
                </div>
                <span class="period">{project.year}</span>
              </div>
              <p class="meta">{project.summary}</p>
              <ul>
                {project.details.map((detail) => <li>{detail}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h2>{labels.awards}</h2>
        {
          cv.awards.map((award) => (
            <article class="entry">
              <div class="entry-header">
                <h3>{award.title}</h3>
                <span class="period">{award.result}</span>
              </div>
              <ul>
                {award.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h2>{labels.leadership}</h2>
        <ul>
          {cv.leadership.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="cv-section">
        <h2>{labels.skills}</h2>
        <div class="skills-list">
          {
            cv.skillGroups.map((group) => (
              <div class="skill-group">
                <strong>{group.label}:</strong> {group.items.join(", ")}
              </div>
            ))
          }
        </div>
      </section>

      <section class="cv-section">
        <h2>{labels.languages}</h2>
        <div class="languages-list">
          {
            cv.languages.map((language) => (
              <div class="language-item">
                <span>{language.name}</span>
                <span class="period">{language.level}</span>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .cv-container {
    max-width: 900px;
    margin: 100px auto 4rem;
    padding: 0 2rem;
  }

  .cv-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .action-btn {
    border: 1px solid var(--text);
    background: transparent;
    color: var(--text);
    padding: 0.55rem 1rem;
    font-family: Georgia, serif;
    text-decoration: none;
    cursor: pointer;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cv-name {
    font-size: 2.3rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .cv-title,
  .cv-contact,
  .meta {
    color: var(--text-light);
  }

  .cv-contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .cv-section {
    margin-bottom: 2rem;
  }

  .cv-section h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .entry {
    margin-bottom: 1.5rem;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .entry h3 {
    font-size: 1.05rem;
    font-weight: 400;
  }

  .period {
    color: var(--text-light);
    white-space: nowrap;
  }

  .entry ul,
  .cv-section ul {
    margin-left: 1.2rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .skills-list {
    display: grid;
    gap: 0.65rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .languages-list {
    display: grid;
    gap: 0.75rem;
  }

  .language-item {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding-bottom: 0.5rem;
  }

  @media print {
    .cv-actions,
    .navigation,
    .decorative-line {
      display: none;
    }

    .cv-container {
      margin: 0;
      padding: 0;
    }
  }

  @media (max-width: 768px) {
    .entry-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .cv-name {
      font-size: 1.9rem;
    }
  }
</style>
