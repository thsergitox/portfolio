---
import Layout from '../../layouts/Layout.astro';
import { getProfile } from '../../data';
import { getLangFromUrl, useTranslations } from '../../i18n/locales';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const profile = getProfile(lang);

const contacts = [
  { label: 'Email', href: `mailto:${profile.email}`, value: profile.email, icon: 'mail' },
  { label: 'Phone', href: `tel:${profile.phone.replace(/\s+/g, '')}`, value: profile.phone, icon: 'phone' },
  { label: 'LinkedIn', href: profile.linkedin, value: 'LinkedIn', icon: 'linkedin' },
  { label: 'GitHub', href: profile.github, value: 'GitHub', icon: 'github' },
  { label: 'Instagram', href: profile.instagram, value: 'Instagram', icon: 'instagram' },
] as const;

const icons = {
  mail: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="m5 7 7 6 7-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  phone: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 4h3l1.1 3.7-1.8 1.8a15.6 15.6 0 0 0 5 5l1.8-1.8L20 14v3c0 .6-.4 1-1 1C10.7 18 6 13.3 6 7c0-.6.4-1 1-1Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 8.5v9M6.5 5.8a.8.8 0 1 1 0 1.6.8.8 0 0 1 0-1.6ZM11 17.5v-5.2c0-1.5 1-2.6 2.4-2.6 1.4 0 2.1.9 2.1 2.6v5.2M11 11c.6-.9 1.5-1.4 2.8-1.4 2 0 3.7 1.3 3.7 4.2v3.7" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  github: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18c-4 1.2-4-2-5.5-2.4M14.5 20v-3.1a2.7 2.7 0 0 0-.8-2.2c2.6-.3 5.3-1.3 5.3-5.8A4.5 4.5 0 0 0 17.8 5a4.2 4.2 0 0 0-.1-3s-1 0-3 1.3a10.2 10.2 0 0 0-5.4 0C7.3 2 6.2 2 6.2 2A4.2 4.2 0 0 0 6 5a4.5 4.5 0 0 0-1.2 3.1c0 4.4 2.7 5.5 5.3 5.8a2.7 2.7 0 0 0-.8 2.2V20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  instagram: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4.5" y="4.5" width="15" height="15" rx="4" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="3.6" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="17.3" cy="6.8" r="1" fill="currentColor"/></svg>',
} as const;
---

<Layout title={t('seo.cvTitle')} description={t('seo.cvDescription')} type="profile">
  <main class="page-shell cv-page">
    <section class="section-card cv-hero">
      <div>
        <h1 class="gradient-title">{profile.name}</h1>
        <p class="cv-location">{profile.location}</p>
        <p class="stacked-text">{profile.summary}</p>
      </div>
      <div class="hero-actions">
        <a href="#cv-pdf-modal" class="pdf-link">{profile.pdfLabel}</a>
      </div>
    </section>

    <section class="contact-grid">
      {contacts.map((item) => (
        <a href={item.href} class="contact-card section-card" target={item.label === 'Email' || item.label === 'Phone' ? undefined : '_blank'} rel="noreferrer">
          <span class="icon" set:html={icons[item.icon]} />
          <span>{item.value}</span>
        </a>
      ))}
    </section>

    <section class="cv-grid">
      <article class="section-card cv-card full-span">
        <h2 class="gradient-title">{t('cv.experienceTitle')}</h2>
        {profile.experience.map((job) => (
          <div class="cv-item">
            <div class="item-head">
              <h3>{job.role} · {job.company}</h3>
              <span>{job.period}</span>
            </div>
            <ul>{job.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
          </div>
        ))}
      </article>

      <article class="section-card cv-card">
        <h2 class="gradient-title">{t('cv.educationTitle')}</h2>
        {profile.education.map((item) => (
          <div class="cv-item">
            <div class="item-head compact">
              <h3>{item.place}</h3>
              <span>{item.period}</span>
            </div>
            <p>{item.detail}</p>
          </div>
        ))}
      </article>

      <article class="section-card cv-card">
        <h2 class="gradient-title">{t('cv.projectsTitle')}</h2>
        <ul>{profile.projects.map((project) => <li>{project}</li>)}</ul>
      </article>

      <article class="section-card cv-card">
        <h2 class="gradient-title">{t('cv.skillsTitle')}</h2>
        <div class="group-list">
          {profile.skillGroups.map((group) => (
            <div class="skill-group">
              <h3>{group.label}</h3>
              <p>{group.items.join(' · ')}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="section-card cv-card">
        <h2 class="gradient-title">{t('cv.languagesTitle')}</h2>
        <ul>{profile.spokenLanguages.map((item) => <li>{item}</li>)}</ul>
      </article>

      <article class="section-card cv-card">
        <h2 class="gradient-title">{t('cv.awardsTitle')}</h2>
        <ul>{profile.awards.map((award) => <li>{award}</li>)}</ul>
      </article>
    </section>

    <div id="cv-pdf-modal" class="pdf-modal">
      <a href="#" class="pdf-backdrop" aria-label={profile.pdfClose}></a>
      <div class="pdf-window section-card">
        <div class="pdf-toolbar">
          <span>{profile.pdfLabel}</span>
          <a href="#" class="pdf-close">{profile.pdfClose}</a>
        </div>
        <iframe src="/cv.pdf#view=FitH" title="CV PDF" class="pdf-frame"></iframe>
      </div>
    </div>
  </main>
</Layout>

<style>
  .cv-page { display: grid; gap: 1.2rem; }
  .cv-hero, .cv-card { padding: 1.45rem; }
  .cv-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }
  .cv-hero h1 { margin: 0; font-size: clamp(2rem, 4.2vw, 3.25rem); }
  .cv-location {
    margin: 0.4rem 0 0;
    color: var(--brown);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
  }
  .stacked-text { margin: 0.9rem 0 0; max-width: 52rem; }
  .pdf-link {
    display: inline-flex;
    text-decoration: none;
    border: 1px solid var(--blue);
    color: var(--blue);
    padding: 0.8rem 1.05rem;
    border-radius: 999px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.9rem;
  }
  .contact-card {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.95rem 1rem;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  .contact-card:hover { transform: translateY(-2px); border-color: rgba(70,112,142,0.28); }
  .icon { width: 1.15rem; height: 1.15rem; color: var(--blue); display: inline-flex; }
  .icon :global(svg) { width: 100%; height: 100%; }
  .cv-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }
  .full-span { grid-column: 1 / -1; }
  .cv-card h2 { margin: 0 0 1rem; font-size: clamp(1.25rem, 1.8vw, 1.65rem); }
  .cv-card ul { margin: 0; padding-left: 1.2rem; display: grid; gap: 0.65rem; }
  .cv-item + .cv-item { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--line); }
  .item-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.45rem;
  }
  .item-head.compact { margin-bottom: 0.2rem; }
  .item-head h3 { margin: 0; font-size: 1rem; }
  .item-head span { color: rgba(45, 37, 32, 0.7); font-size: 0.95rem; }
  .cv-item p { margin: 0; }
  .group-list { display: grid; gap: 0.95rem; }
  .skill-group h3 { margin: 0 0 0.3rem; font-size: 0.95rem; color: var(--blue); }
  .skill-group p { margin: 0; }
  .pdf-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 60;
  }
  .pdf-modal:target { display: flex; }
  .pdf-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 18, 17, 0.58);
    backdrop-filter: blur(8px);
  }
  .pdf-window {
    position: relative;
    z-index: 1;
    width: min(1000px, calc(100vw - 2rem));
    height: min(85vh, 860px);
    padding: 0;
    overflow: hidden;
    background: rgba(251, 247, 244, 0.98);
  }
  .pdf-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--line);
  }
  .pdf-close { text-decoration: none; color: var(--blue); }
  .pdf-frame { width: 100%; height: calc(100% - 56px); border: 0; }
  @media (max-width: 920px) {
    .contact-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cv-grid { grid-template-columns: 1fr; }
    .cv-hero { flex-direction: column; align-items: start; }
  }
  @media (max-width: 560px) {
    .contact-grid { grid-template-columns: 1fr; }
    .item-head { flex-direction: column; align-items: start; gap: 0.3rem; }
  }
</style>
