---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/locales';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = (await getCollection('blog', ({ data }) => data.locale === lang && !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={t('seo.blogTitle')} description={t('seo.blogDescription')}>
  <main class="page-shell blog-page">
    <section class="section-card blog-hero">
      <div class="glow"></div>
      <p class="mini-title">{t('blog.title')}</p>
      <h1 class="gradient-title">{t('blog.description')}</h1>
      <p>{t('blog.markdownBody')}</p>
    </section>

    <section class="post-grid">
      {posts.length ? posts.map((post) => {
        const href = lang === 'es' ? `/blog/${post.id.split('/').pop()?.replace(/\.md$/, '')}` : `/${lang}/blog/${post.id.split('/').pop()?.replace(/\.md$/, '')}`;
        return (
          <a href={href} class="post-link-card">
            <article class="section-card post-card">
              {post.data.cover && <img src={post.data.cover} alt={post.data.title} class="post-cover" />}
              <div class="post-body">
                <p class="post-date">{post.data.date.toLocaleDateString(lang === 'pt' ? 'pt-BR' : lang === 'en' ? 'en-US' : 'es-PE', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                <h2 class="gradient-title">{post.data.title}</h2>
                <p>{post.data.description}</p>
                <div class="post-footer">
                  <div class="tag-list">{post.data.tags.map((tag) => <span class="pill">{tag}</span>)}</div>
                  <span class="read-more">{t('blog.readMore')}</span>
                </div>
              </div>
            </article>
          </a>
        );
      }) : <p>{t('blog.empty')}</p>}
    </section>
  </main>
</Layout>

<style>
  .blog-page { display: grid; gap: 1.5rem; }
  .blog-hero, .post-card { padding: 1.4rem; }
  .blog-hero {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(70,112,142,0.14), rgba(177,144,116,0.14)),
      var(--surface);
  }
  .glow {
    position: absolute;
    inset: auto -50px -80px auto;
    width: 220px;
    height: 220px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(70,112,142,0.18), transparent 70%);
    pointer-events: none;
  }
  .blog-hero h1 { margin: 0; font-size: clamp(1.8rem, 3.2vw, 2.7rem); max-width: 24ch; }
  .blog-hero p:last-child { max-width: 58rem; margin: 0; }
  .post-grid { display: grid; gap: 1.4rem; }
  .post-link-card { text-decoration: none; display: block; }
  .post-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.2rem;
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  .post-link-card:hover .post-card {
    transform: translateY(-4px);
    box-shadow: 0 28px 55px rgba(70, 112, 142, 0.16);
    border-color: rgba(70, 112, 142, 0.28);
  }
  .post-cover {
    width: 100%;
    height: 100%;
    min-height: 240px;
    object-fit: cover;
    border-radius: 20px;
    background: linear-gradient(120deg, rgba(70,112,142,0.2), rgba(177,144,116,0.18));
  }
  .post-date { margin: 0; color: var(--blue); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; }
  .post-body h2 { margin: 0.45rem 0 0.7rem; font-size: clamp(1.35rem, 2.2vw, 1.9rem); }
  .post-body p { margin: 0; }
  .post-footer { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 1.2rem; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .read-more { color: var(--blue); font-weight: 600; }
  @media (max-width: 760px) {
    .post-card { grid-template-columns: 1fr; }
    .post-cover { min-height: 200px; }
  }
</style>
