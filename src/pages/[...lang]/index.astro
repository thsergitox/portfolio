---
import Layout from "../../layouts/Layout.astro";
import SocialIcons from "../../components/SocialIcons.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";
import { getProfile } from "../../data/profile";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
    { params: { lang: "pt" } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const profile = getProfile(lang);
const featuredProjects = profile.projects.slice(0, 4);
const profileImage =
  "https://media.licdn.com/dms/image/v2/D4E03AQFNd1CkPp5FOg/profile-displayphoto-shrink_400_400/profile-displayphoto-shrink_400_400/0/1695266233679?e=1778112000&v=beta&t=6am0sRqfvkTCRrH5uxbE3OcaFvICVz7jelgcskXZJx0";
---

<Layout title="Portfolio">
  <main transition:animate>
    <section class="hero">
      <div class="profile-container">
        <img src={profileImage} alt={t("hero.name")} class="profile-image" />
        <p class="eyebrow">{profile.metaTitle}</p>
        <h1 class="name">{t("hero.name")}</h1>
        <p class="headline">{profile.headline}</p>
        <p class="description">{profile.summary}</p>
        <div class="meta">
          <span>{profile.location}</span>
          <span>{profile.education[0].institution}</span>
          <span>{profile.education[1].institution}</span>
        </div>
        <SocialIcons className="hero-social" />
      </div>
    </section>

    <section class="split-section">
      <div class="section-block">
        <h2 class="section-title">{t("home.experience")}</h2>
        {
          profile.experience.map((job) => (
            <article class="detail-card">
              <div class="card-heading">
                <div>
                  <h3>{job.role}</h3>
                  <p>{job.company} · {job.location}</p>
                </div>
                <span>{job.period}</span>
              </div>
              <ul>
                {job.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))
        }
      </div>

      <div class="section-block">
        <h2 class="section-title">{t("home.education")}</h2>
        {
          profile.education.map((item) => (
            <article class="detail-card">
              <div class="card-heading">
                <div>
                  <h3>{item.institution}</h3>
                  <p>{item.program}</p>
                </div>
                <span>{item.period}</span>
              </div>
              <p class="detail-location">{item.location}</p>
              <ul>
                {item.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="projects">
      <div class="section-header">
        <h2 class="section-title">{t("projects.title")}</h2>
        <a href={lang === "es" ? "/proyectos" : `/${lang}/proyectos`} class="view-more-link">
          {t("projects.viewMore")}
        </a>
      </div>
      <div class="projects-grid">
        {
          featuredProjects.map((project) => (
            <article class="project-card">
              <span class="project-year">{project.year}</span>
              <h3 class="project-title">{project.title}</h3>
              <p class="project-description">{project.summary}</p>
              <p class="project-stack">{project.stack.join(" · ")}</p>
              <a
                href={lang === "es" ? `/proyectos/${project.id}` : `/${lang}/proyectos/${project.id}`}
                class="project-link"
              >
                {t("projects.viewProject")}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="split-section">
      <div class="section-block">
        <h2 class="section-title">{t("home.awards")}</h2>
        <div class="awards-list">
          {
            profile.awards.map((award) => (
              <article class="detail-card">
                <div class="card-heading">
                  <h3>{award.title}</h3>
                  <span>{award.result}</span>
                </div>
                <ul>
                  {award.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </div>

      <div class="section-block">
        <h2 class="section-title">{t("home.skills")}</h2>
        <div class="skills-groups">
          {
            profile.skillGroups.map((group) => (
              <article class="detail-card skill-card">
                <h3>{group.label}</h3>
                <div class="skill-tags">
                  {group.items.map((item) => <span class="skill-tag">{item}</span>)}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1160px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .hero {
    min-height: 68vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 0 2rem;
  }

  .profile-container {
    max-width: 760px;
    text-align: center;
  }

  .profile-image {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    filter: grayscale(10%);
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 0.75rem;
  }

  .name {
    font-size: 3rem;
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .headline {
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-light);
    margin: 0 auto 1.5rem;
    max-width: 680px;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .meta span {
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    font-size: 0.9rem;
    color: var(--text-light);
  }

  :global(.hero-social) {
    justify-content: center;
  }

  .split-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 2rem 0;
  }

  .section-block {
    min-width: 0;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
  }

  .detail-card,
  .project-card {
    background: rgba(255, 255, 255, 0.38);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .detail-card + .detail-card {
    margin-top: 1rem;
  }

  .card-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .card-heading h3,
  .project-title,
  .skill-card h3 {
    font-size: 1.1rem;
    font-weight: 400;
    margin: 0;
  }

  .card-heading p,
  .detail-location,
  .project-description,
  .project-stack {
    color: var(--text-light);
  }

  .detail-location {
    margin-bottom: 0.75rem;
  }

  .detail-card ul {
    margin-left: 1.2rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .projects {
    padding: 2rem 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .project-year {
    font-size: 0.85rem;
    color: var(--text-light);
    letter-spacing: 0.08em;
  }

  .project-description {
    line-height: 1.7;
    margin: 0.75rem 0;
  }

  .project-stack {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .project-link,
  .view-more-link {
    color: var(--text);
    text-decoration: none;
  }

  .view-more-link {
    font-size: 0.95rem;
    border-bottom: 1px solid currentColor;
  }

  .awards-list,
  .skills-groups {
    display: grid;
    gap: 1rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .skill-tag {
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0.35rem 0.7rem;
    font-size: 0.88rem;
    color: var(--text-light);
  }

  @media (max-width: 900px) {
    .split-section,
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 2rem;
    }

    .name {
      font-size: 2.2rem;
    }

    .headline {
      font-size: 1.1rem;
    }

    .card-heading {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
