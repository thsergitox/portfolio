---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getProfile } from '../../data';
import { getLangFromUrl, localizePath, useTranslations } from '../../i18n/locales';

export function getStaticPaths() {
  return [{ params: { lang: undefined } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const profile = getProfile(lang);
const latestPost = (await getCollection('blog', ({ data }) => data.locale === lang && !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
const latestHref = latestPost
  ? lang === 'es'
    ? `/blog/${latestPost.id.split('/').pop()?.replace(/\.md$/, '')}`
    : `/${lang}/blog/${latestPost.id.split('/').pop()?.replace(/\.md$/, '')}`
  : localizePath(lang, '/blog');
---

<Layout>
  <main class="page-shell home-page">
    <section class="hero section-card">
      <div class="hero-copy">
        <p class="kicker">{t('hero.kicker')}</p>
        <h1 class="gradient-title">{t('hero.name')}</h1>
        <p class="hero-role">{t('hero.role')}</p>
        <p class="hero-summary">{t('hero.summary')}</p>
        <div class="hero-actions">
          <a href={localizePath(lang, '/cv')} class="primary-link">{t('hero.ctaPrimary')}</a>
          <a href={localizePath(lang, '/blog')} class="secondary-link">{t('hero.ctaSecondary')}</a>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <div class="photo-frame">
          <img src="/photo.jpeg" alt={t('hero.name')} class="hero-photo" />
        </div>
      </div>
    </section>

    <section class="home-grid minimalist-grid">
      <article class="section-card content-card accent-blue">
        <p class="mini-title">{t('home.aboutTitle')}</p>
        <p>{t('home.aboutBody')}</p>
      </article>
      <article class="section-card content-card accent-brown">
        <p class="mini-title">{t('home.focusTitle')}</p>
        <p>{t('home.focusBody')}</p>
      </article>
    </section>

    {latestPost && (
      <a href={latestHref} class="latest-story-link">
        <section class="section-card latest-story">
          <div class="latest-story-copy">
            <p class="mini-title">{t('home.latestStoryTitle')}</p>
            <h2 class="gradient-title">{latestPost.data.title}</h2>
            <p>{latestPost.data.description}</p>
            <span class="story-cta">{t('home.latestStoryLink')}</span>
          </div>
          {latestPost.data.cover && <img src={latestPost.data.cover} alt={latestPost.data.title} class="latest-story-cover" />}
        </section>
      </a>
    )}
  </main>
</Layout>

<style>
  .home-page { display: grid; gap: 1.25rem; }
  .hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    align-items: center;
    padding: 1.9rem;
    min-height: 68vh;
  }
  .kicker {
    margin: 0 0 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--blue);
  }
  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    max-width: 11ch;
  }
  .hero-role {
    margin: 0.9rem 0 0;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    color: var(--brown);
    max-width: 34rem;
  }
  .hero-summary, .content-card p, .latest-story p {
    margin: 0;
    max-width: 42rem;
  }
  .hero-summary { margin-top: 0.9rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.2rem; }
  .primary-link, .secondary-link {
    text-decoration: none;
    border-radius: 999px;
    padding: 0.82rem 1.14rem;
    border: 1px solid var(--blue);
    transition: 180ms ease;
  }
  .primary-link { background: var(--blue); color: white; }
  .secondary-link { color: var(--blue); }
  .primary-link:hover, .secondary-link:hover { transform: translateY(-1px); }
  .hero-photo-wrap { display: flex; justify-content: center; }
  .photo-frame {
    position: relative;
    width: min(100%, 345px);
    border-radius: 32px;
    padding: 0.9rem;
    background: linear-gradient(180deg, rgba(70,112,142,0.16), rgba(177,144,116,0.18));
  }
  .photo-frame::after {
    content: '';
    position: absolute;
    inset: 14px -10px -14px 14px;
    border: 1px solid rgba(177,144,116,0.32);
    border-radius: 32px;
    z-index: 0;
  }
  .hero-photo {
    position: relative;
    z-index: 1;
    aspect-ratio: 1 / 1.14;
    width: 100%;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 18px 50px rgba(45,37,32,0.14);
  }
  .minimalist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .content-card, .latest-story { padding: 1.45rem; }
  .mini-title {
    margin: 0 0 0.75rem;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
  }
  .accent-blue { background: rgba(70, 112, 142, 0.08); }
  .accent-brown { background: rgba(177, 144, 116, 0.1); }
  .latest-story-link { text-decoration: none; display: block; }
  .latest-story {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.2rem;
    align-items: center;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  .latest-story-link:hover .latest-story {
    transform: translateY(-4px);
    box-shadow: 0 26px 52px rgba(70,112,142,0.15);
    border-color: rgba(70,112,142,0.28);
  }
  .latest-story h2 {
    margin: 0 0 0.7rem;
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
  }
  .story-cta {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--blue);
    font-weight: 600;
  }
  .latest-story-cover {
    width: 100%;
    min-height: 210px;
    object-fit: cover;
    border-radius: 20px;
    background: linear-gradient(120deg, rgba(70,112,142,0.12), rgba(177,144,116,0.12));
  }
  @media (max-width: 900px) {
    .hero, .minimalist-grid, .latest-story { grid-template-columns: 1fr; }
    .hero { min-height: auto; }
    h1 { max-width: none; }
    .hero-photo-wrap { order: -1; }
  }
</style>
