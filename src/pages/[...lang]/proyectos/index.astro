---
import Layout from "../../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/locales";
import { getProfile } from "../../../data/profile";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
    { params: { lang: "pt" } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const profile = getProfile(lang);
---

<Layout title={t("projects.title")}>
  <main transition:animate>
    <section class="projects">
      <h1 class="page-title">{t("projects.title")}</h1>
      <div class="projects-grid">
        {
          profile.projects.map((project) => (
            <article class="project-card">
              <span class="project-year">{project.year}</span>
              <h3 class="project-title">{project.title}</h3>
              <p class="project-description">{project.summary}</p>
              <p class="project-stack">{project.stack.join(" · ")}</p>
              <a
                href={lang === "es" ? `/proyectos/${project.id}` : `/${lang}/proyectos/${project.id}`}
                class="project-link"
              >
                {t("projects.viewProject")}
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .projects {
    padding: 4rem 0;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 3rem;
    text-align: center;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    padding: 0 1rem;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.75rem;
    border-radius: 8px;
  }

  .project-year {
    font-size: 0.875rem;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0.5rem 0 0.75rem;
    color: var(--text);
  }

  .project-description,
  .project-stack {
    color: var(--text-light);
    line-height: 1.7;
  }

  .project-stack {
    font-size: 0.92rem;
    margin: 1rem 0;
  }

  .project-link {
    color: var(--text);
    text-decoration: none;
  }
</style>
