---
import Layout from "../../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/locales";
import { getProfile } from "../../../data/profile";

export function getStaticPaths() {
  const langs = [undefined, "en", "pt"];
  const ids = ["1", "2", "3", "4", "5"];

  return langs.flatMap((lang) =>
    ids.map((id) => ({
      params: { lang, id },
      props: { projectId: id },
    })),
  );
}

const { projectId } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const project = getProfile(lang).projects.find((item) => item.id === projectId);

if (!project) {
  throw new Error(`Project ${projectId} not found`);
}
---

<Layout title={project.title}>
  <main transition:animate>
    <header class="project-header">
      <a href={lang === "es" ? "/" : `/${lang}`} class="back-link">{t("projects.back")}</a>
      <div class="project-info">
        <span class="project-year">{project.year}</span>
        <h1 class="project-title">{project.title}</h1>
        <p class="project-description">{project.summary}</p>
      </div>
    </header>

    <section class="project-details">
      <div class="project-body">
        <h2>{t("projects.viewProject")}</h2>
        <ul class="detail-list">
          {project.details.map((detail) => <li>{detail}</li>)}
        </ul>
      </div>

      <aside class="project-sidebar">
        <div class="sidebar-card">
          <h3>{t("projects.technologies")}</h3>
          <ul class="tech-list">
            {project.stack.map((tech) => <li class="tech-item">{tech}</li>)}
          </ul>
        </div>

        {
          project.github && (
            <div class="sidebar-card">
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-link">
                {t("projects.viewCode")}
              </a>
            </div>
          )
        }
      </aside>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .project-header {
    padding: 2rem 0 3rem;
  }

  .back-link {
    color: var(--text);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
  }

  .project-info {
    max-width: 820px;
  }

  .project-year {
    font-size: 0.875rem;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }

  .project-title {
    font-size: 3rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0.5rem 0 1rem;
  }

  .project-description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-light);
  }

  .project-details {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(260px, 0.8fr);
    gap: 2rem;
  }

  .project-body,
  .sidebar-card {
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .project-body h2,
  .sidebar-card h3 {
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .detail-list {
    margin-left: 1.2rem;
    color: var(--text-light);
    line-height: 1.8;
  }

  .project-sidebar {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .tech-list {
    list-style: none;
    padding: 0;
  }

  .tech-item {
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--text-light);
  }

  .tech-item:last-child {
    border-bottom: 0;
  }

  .project-link {
    color: var(--text);
    text-decoration: none;
  }

  @media (max-width: 800px) {
    .project-title {
      font-size: 2rem;
    }

    .project-details {
      grid-template-columns: 1fr;
    }
  }
</style>
