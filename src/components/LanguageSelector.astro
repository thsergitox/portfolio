---
import { languages, localizePath } from '../i18n/locales';

interface Props {
  currentLang: keyof typeof languages;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;
---

<div class="language-selector" aria-label="Language selector">
  {Object.entries(languages).map(([lang, label]) => (
    <a
      href={localizePath(lang as keyof typeof languages, currentPath)}
      class:list={["lang-button", { active: currentLang === lang }]}
      hreflang={lang}
      aria-label={label}
    >
      {lang.toUpperCase()}
    </a>
  ))}
</div>
