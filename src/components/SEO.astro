---
import { defaultLang, languages, localizePath, stripLocale, type Lang } from '../i18n/locales';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  image = '/og-default.png',
  type = 'website',
  publishedTime,
  tags = [],
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://pezo.dev');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(image, siteUrl);

const localeMap: Record<Lang, string> = {
  es: 'es_PE',
  en: 'en_US',
  pt: 'pt_BR',
};

const cleanPath = stripLocale(Astro.url.pathname);
const alternates = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  href: new URL(localizePath(code, cleanPath), siteUrl).toString(),
}));
const defaultAlternate = new URL(localizePath(defaultLang, cleanPath), siteUrl).toString();

const robots = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="author" content="Sergio Pezo" />
<meta name="theme-color" content="#46708e" />
<meta name="color-scheme" content="light" />

<link rel="canonical" href={canonicalURL} />

{alternates.map((alt) => (
  <link rel="alternate" hreflang={alt.code} href={alt.href} />
))}
<link rel="alternate" hreflang="x-default" href={defaultAlternate} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Sergio Pezo · Software Engineering Studio" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:locale" content={localeMap[lang]} />
{(Object.keys(languages) as Lang[])
  .filter((code) => code !== lang)
  .map((code) => (
    <meta property="og:locale:alternate" content={localeMap[code]} />
  ))}
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImageURL} />
<meta name="twitter:creator" content="@sergiopezoj" />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
