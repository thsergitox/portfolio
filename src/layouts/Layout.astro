---
import { ViewTransitions } from 'astro:transitions';
import LanguageSelector from '../components/LanguageSelector.astro';
import SEO from '../components/SEO.astro';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/locales';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  tags?: string[];
  noindex?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const {
  title = t('seo.defaultTitle'),
  description = t('seo.defaultDescription'),
  image,
  type = 'website',
  publishedTime,
  tags,
  noindex,
} = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { key: 'nav.home', href: localizePath(lang, '/') },
  { key: 'nav.blog', href: localizePath(lang, '/blog') },
  { key: 'nav.cv', href: localizePath(lang, '/cv') },
] as const;

const contactHref = localizePath(lang, '/contact');

const siteUrl = Astro.site ?? new URL('https://pezo.dev');
const homeUrl = new URL(localizePath(lang, '/'), siteUrl).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sergio Pezo',
  alternateName: 'Sergio Sebastián Pezo Jiménez',
  url: siteUrl.toString(),
  image: new URL('/photo.jpeg', siteUrl).toString(),
  jobTitle: 'Software Engineer',
  description: t('seo.defaultDescription'),
  sameAs: [
    'https://github.com/thsergitox',
    'https://linkedin.com/in/sergio-pezo',
    'https://instagram.com/sergiopezoj',
  ],
  knowsAbout: [
    'Backend engineering',
    'Distributed systems',
    'Applied AI',
    'TypeScript',
    'Python',
    'Go',
    'NestJS',
    'FastAPI',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lima',
    addressCountry: 'PE',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Sergio Pezo · Software Engineering Studio',
  url: homeUrl,
  inLanguage: lang === 'es' ? 'es-PE' : lang === 'en' ? 'en-US' : 'pt-BR',
  author: { '@type': 'Person', name: 'Sergio Pezo' },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      publishedTime={publishedTime}
      tags={tags}
      noindex={noindex}
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} is:inline />
    <ViewTransitions />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell">
        <div class="header-card desktop-header">
          <nav class="main-nav" aria-label="Primary navigation">
            <div class="nav-links">
              {navItems.map((item) => (
                <a href={item.href} class:list={["nav-link", { active: currentPath === item.href }]}> 
                  {t(item.key)}
                </a>
              ))}
              <a href={contactHref} class:list={["nav-link", "nav-cta", { active: currentPath === contactHref }]}>
                {t('nav.contact')}
              </a>
            </div>
            <LanguageSelector currentLang={lang} currentPath={currentPath} />
          </nav>
          <div class="header-line" aria-hidden="true"></div>
        </div>

        <details class="mobile-menu">
          <summary class="mobile-trigger">menu</summary>
          <div class="mobile-panel section-card">
            <nav class="mobile-nav" aria-label="Mobile navigation">
              {navItems.map((item) => (
                <a href={item.href} class:list={["nav-link", "mobile-link", { active: currentPath === item.href }]}> 
                  {t(item.key)}
                </a>
              ))}
              <a href={contactHref} class:list={["nav-link", "mobile-link", "nav-cta", { active: currentPath === contactHref }]}>
                {t('nav.contact')}
              </a>
            </nav>
            <LanguageSelector currentLang={lang} currentPath={currentPath} />
          </div>
          <div class="header-line mobile-line" aria-hidden="true"></div>
        </details>
      </div>
    </header>
    <slot />

    {currentPath !== contactHref && (
      <a href={contactHref} class="sticky-cta" aria-label={t('cta.sticky')}>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="sticky-cta-icon">
          <path d="M5 5h14v11H8l-3 3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
        </svg>
        <span>{t('cta.sticky')}</span>
      </a>
    )}
  </body>
</html>

<style is:global>
  :root {
    --blue: #46708e;
    --beige: #e3cbaf;
    --beige-light: #e3dad5;
    --brown: #b19074;
    --ink: #2d2520;
    --surface: rgba(255, 249, 244, 0.68);
    --surface-strong: rgba(255, 250, 246, 0.88);
    --line: rgba(45, 37, 32, 0.18);
    --shadow: 0 20px 45px rgba(70, 112, 142, 0.12);
    --text-space: 1.78;
    --title-gradient: linear-gradient(120deg, var(--blue) 0%, var(--brown) 100%);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(70, 112, 142, 0.22), transparent 32%),
      linear-gradient(180deg, #efe4db 0%, var(--beige-light) 100%);
  }
  a { color: inherit; }
  img { display: block; max-width: 100%; }
  p, li { line-height: var(--text-space); }
  h1, h2, h3 {
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .gradient-title {
    background: var(--title-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 1rem 0;
    backdrop-filter: blur(10px);
  }

  .header-shell {
    width: min(100%, 980px);
    margin: 0 auto;
  }

  .header-card {
    width: 100%;
    margin: 0 auto;
  }

  .main-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.95rem 1.15rem 0.65rem;
    background: rgba(255, 250, 246, 0.82);
    border: 1px solid rgba(177, 144, 116, 0.22);
    border-radius: 999px;
    box-shadow: var(--shadow);
  }

  .nav-links, .language-selector, .mobile-nav {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .nav-link, .lang-button, .mobile-trigger {
    text-decoration: none;
    text-transform: lowercase;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    transition: 180ms ease;
    border: 1px solid transparent;
    white-space: nowrap;
    font-size: 0.94rem;
    background: transparent;
    color: var(--ink);
    font: inherit;
  }

  .nav-link:hover, .lang-button:hover, .mobile-trigger:hover {
    color: var(--blue);
    border-color: rgba(70, 112, 142, 0.22);
    background: rgba(70, 112, 142, 0.08);
  }

  .nav-link.active, .lang-button.active {
    color: #fff;
    background: var(--blue);
    border-color: var(--blue);
  }

  .nav-link.nav-cta {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
    font-weight: 600;
  }
  .nav-link.nav-cta:hover {
    background: #1d1712;
    color: #fff;
    border-color: #1d1712;
    transform: translateY(-1px);
  }

  .sticky-cta {
    position: fixed;
    right: 1.2rem;
    bottom: 1.2rem;
    z-index: 30;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    background: var(--ink);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 18px 40px rgba(45, 37, 32, 0.28);
    transition: transform 180ms ease, background 180ms ease;
  }
  .sticky-cta:hover {
    background: #1d1712;
    transform: translateY(-2px);
  }
  .sticky-cta-icon {
    width: 1.05rem;
    height: 1.05rem;
    color: currentColor;
  }
  @media (max-width: 560px) {
    .sticky-cta {
      right: 0.9rem;
      bottom: 0.9rem;
      padding: 0.7rem 0.95rem;
      font-size: 0.88rem;
    }
  }

  .header-line {
    width: min(56%, 440px);
    height: 1px;
    margin: 0.9rem auto 0;
    background: linear-gradient(90deg, transparent, rgba(177, 144, 116, 0.95), transparent);
  }

  .mobile-menu {
    display: none;
    gap: 0.55rem;
  }

  .mobile-trigger {
    list-style: none;
    cursor: pointer;
    width: fit-content;
    margin: 0 auto;
    background: var(--surface-strong);
    border: 1px solid rgba(177, 144, 116, 0.22);
    box-shadow: var(--shadow);
  }

  .mobile-trigger::-webkit-details-marker { display: none; }
  .mobile-panel {
    margin-top: 0;
    padding: 0 1rem;
    background: var(--surface-strong);
    max-height: 0;
    opacity: 0;
    transform: translateY(-8px);
    overflow: hidden;
    transition: max-height 320ms ease, opacity 240ms ease, transform 320ms ease, padding 320ms ease;
    pointer-events: none;
  }

  .mobile-menu[open] .mobile-panel {
    max-height: 420px;
    opacity: 1;
    transform: translateY(0);
    padding: 1rem;
    pointer-events: auto;
  }

  .mobile-menu:not([open]) .mobile-panel {
    border-color: transparent;
    box-shadow: none;
  }

  .mobile-nav {
    flex-direction: column;
    align-items: stretch;
    margin-bottom: 0.8rem;
  }

  .mobile-link, .mobile-panel .language-selector {
    width: 100%;
    justify-content: center;
  }

  .mobile-panel .language-selector {
    display: flex;
    flex-wrap: wrap;
  }

  .mobile-line { width: min(42%, 180px); }

  .page-shell {
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .section-card {
    background: var(--surface);
    border: 1px solid rgba(177, 144, 116, 0.24);
    border-radius: 28px;
    box-shadow: var(--shadow);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(177, 144, 116, 0.12);
    border: 1px solid rgba(177, 144, 116, 0.28);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .site-header { padding-inline: 0.5rem; }
    .page-shell { width: min(100% - 1rem, 1100px); padding-top: 1.35rem; }
    .desktop-header { display: none; }
    .mobile-menu { display: grid; }
  }
</style>
