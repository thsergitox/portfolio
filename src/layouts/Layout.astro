---
import { ViewTransitions } from 'astro:transitions';
import LanguageSelector from '../components/LanguageSelector.astro';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/locales';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title = t('site.title'), description = t('site.description') } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { key: 'nav.home', href: localizePath(lang, '/') },
  { key: 'nav.blog', href: localizePath(lang, '/blog') },
  { key: 'nav.cv', href: localizePath(lang, '/cv') },
] as const;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell">
        <div class="header-card desktop-header">
          <nav class="main-nav" aria-label="Primary navigation">
            <div class="nav-links">
              {navItems.map((item) => (
                <a href={item.href} class:list={["nav-link", { active: currentPath === item.href }]}> 
                  {t(item.key)}
                </a>
              ))}
            </div>
            <LanguageSelector currentLang={lang} currentPath={currentPath} />
          </nav>
          <div class="header-line" aria-hidden="true"></div>
        </div>

        <details class="mobile-menu">
          <summary class="mobile-trigger">menu</summary>
          <div class="mobile-panel section-card">
            <nav class="mobile-nav" aria-label="Mobile navigation">
              {navItems.map((item) => (
                <a href={item.href} class:list={["nav-link", "mobile-link", { active: currentPath === item.href }]}> 
                  {t(item.key)}
                </a>
              ))}
            </nav>
            <LanguageSelector currentLang={lang} currentPath={currentPath} />
          </div>
          <div class="header-line mobile-line" aria-hidden="true"></div>
        </details>
      </div>
    </header>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --blue: #46708e;
    --beige: #e3cbaf;
    --beige-light: #e3dad5;
    --brown: #b19074;
    --ink: #2d2520;
    --surface: rgba(255, 249, 244, 0.68);
    --surface-strong: rgba(255, 250, 246, 0.88);
    --line: rgba(45, 37, 32, 0.18);
    --shadow: 0 20px 45px rgba(70, 112, 142, 0.12);
    --text-space: 1.78;
    --title-gradient: linear-gradient(120deg, var(--blue) 0%, var(--brown) 100%);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(70, 112, 142, 0.22), transparent 32%),
      linear-gradient(180deg, #efe4db 0%, var(--beige-light) 100%);
  }
  a { color: inherit; }
  img { display: block; max-width: 100%; }
  p, li { line-height: var(--text-space); }
  h1, h2, h3 {
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .gradient-title {
    background: var(--title-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 1rem 0;
    backdrop-filter: blur(10px);
  }

  .header-shell {
    width: min(100%, 980px);
    margin: 0 auto;
  }

  .header-card {
    width: 100%;
    margin: 0 auto;
  }

  .main-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.95rem 1.15rem 0.65rem;
    background: rgba(255, 250, 246, 0.82);
    border: 1px solid rgba(177, 144, 116, 0.22);
    border-radius: 999px;
    box-shadow: var(--shadow);
  }

  .nav-links, .language-selector, .mobile-nav {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .nav-link, .lang-button, .mobile-trigger {
    text-decoration: none;
    text-transform: lowercase;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    transition: 180ms ease;
    border: 1px solid transparent;
    white-space: nowrap;
    font-size: 0.94rem;
    background: transparent;
    color: var(--ink);
    font: inherit;
  }

  .nav-link:hover, .lang-button:hover, .mobile-trigger:hover {
    color: var(--blue);
    border-color: rgba(70, 112, 142, 0.22);
    background: rgba(70, 112, 142, 0.08);
  }

  .nav-link.active, .lang-button.active {
    color: #fff;
    background: var(--blue);
    border-color: var(--blue);
  }

  .header-line {
    width: min(56%, 440px);
    height: 1px;
    margin: 0.9rem auto 0;
    background: linear-gradient(90deg, transparent, rgba(177, 144, 116, 0.95), transparent);
  }

  .mobile-menu {
    display: none;
  }

  .mobile-trigger {
    list-style: none;
    cursor: pointer;
    width: fit-content;
    margin: 0 auto;
    background: var(--surface-strong);
    border: 1px solid rgba(177, 144, 116, 0.22);
    box-shadow: var(--shadow);
  }

  .mobile-trigger::-webkit-details-marker { display: none; }
  .mobile-panel {
    margin-top: 0.7rem;
    padding: 1rem;
    background: var(--surface-strong);
  }

  .mobile-nav {
    flex-direction: column;
    align-items: stretch;
    margin-bottom: 0.8rem;
  }

  .mobile-link, .mobile-panel .language-selector {
    width: 100%;
    justify-content: center;
  }

  .mobile-panel .language-selector {
    display: flex;
    flex-wrap: wrap;
  }

  .mobile-line { width: min(42%, 180px); }

  .page-shell {
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .section-card {
    background: var(--surface);
    border: 1px solid rgba(177, 144, 116, 0.24);
    border-radius: 28px;
    box-shadow: var(--shadow);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(177, 144, 116, 0.12);
    border: 1px solid rgba(177, 144, 116, 0.28);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .site-header { padding-inline: 0.5rem; }
    .page-shell { width: min(100% - 1rem, 1100px); padding-top: 1.35rem; }
    .desktop-header { display: none; }
    .mobile-menu { display: block; }
  }
</style>
